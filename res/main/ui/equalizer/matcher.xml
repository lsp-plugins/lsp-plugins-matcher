<plugin resizable="true">
	<grid rows="2" cols="1">
		<hbox>
			<label text="labels.fft.frame" />
			<combo id="fft" />
			<label text="labels.signal.reference" />
			<combo id="ref_src" />
			<label text="labels.capture" />
			<combo id="cap_src" />
			<button id="profile" text="actions.profile" />
			<button id="profile" />
		</hbox>
		<graph ui:id="profile_graph" width.min="640" height.min="380" expand="true">
			<origin hpos="-1" vpos="-1" visible="false"/>

			<!-- Gray grid -->
			<ui:for id="g" first="-36" last="36" step="24">
				<marker v="${g} db" ox="1" oy="0" color="graph_alt_1"/>
			</ui:for>
			<ui:with ox="0" oy="1">
				<ui:for id="f" first="20" last="90" step="10">
					<marker v="${f}" color="graph_alt_1"/>
				</ui:for>
				<ui:for id="f" first="200" last="900" step="100">
					<marker v="${f}" color="graph_alt_1"/>
				</ui:for>
				<ui:for id="f" first="2000" last="9000" step="1000">
					<marker v="${f}" color="graph_alt_1"/>
				</ui:for>
				<marker value="20000" color="graph_alt_1"/>
			</ui:with>

			<!-- Yellow grid -->
			<ui:with ox="0" oy="1" color="graph_sec">
				<marker v="100"/>
				<marker v="1000"/>
				<marker v="10000"/>
			</ui:with>
			<ui:with ox="1" oy="0" color="graph_sec">
				<marker v="+24 db"/>
				<marker v="0 db"/>
				<marker v="-24 db"/>
			</ui:with>

			<!-- Piano keys -->
			<embed oy="2" start.x="midi_freq_start(12, 127)" start.y="20" end.x="midi_freq_end(12, 127)" end.y="44" valign="1" alpha="0" visibility=":_ui_graph_piano_layout">
				<piano natural="false" note.min="12" note.max="127" height="24" editable="false" selectable="false" border="0"/>
			</embed>

			<!-- Octave text -->
			<ui:with ox="0" oy="2" y="44" halign="1" valign="1" pgroup="0" priority="10" visibility=":_ui_graph_piano_layout" pad.b="2">
				<ui:for id="octave" first="0" last="9">
					<text x="midi_freq(12 * ${:octave + 1})" text="lists.notes.fmt.c" text:octave="${octave}" valign="1" halign="0"/>
				</ui:for>
			</ui:with>

			<!-- Axis -->
			<axis ui:id="para_eq_ox" min="10" max="24000" color="graph_prim" angle="0.0" log="true" visibility="false"/>
			<axis ui:id="para_eq_oy" min="-48 db" max="48 db" color="graph_prim" angle="0.5" log="true" visibility="false"/>
			<axis min="0" max=":_a_scaled_height" visibility="false" angle="0.5"/>

			<!-- Text -->
			<ui:with ox="0" oy="2" y="0" halign="1" valign="1" pgroup="0" priority="0">
				<text x="10" text="graph.units.hz"/>
				<text x="20" text="20"/>
				<text x="30" text="30"/>
				<text x="50" text="50"/>
				<text x="100" text="100"/>
				<text x="200" text="200"/>
				<text x="300" text="300"/>
				<text x="500" text="500"/>
				<text x="1000" text="graph.values.x_k" text:value="1"/>
				<text x="2000" text="graph.values.x_k" text:value="2"/>
				<text x="3000" text="graph.values.x_k" text:value="3"/>
				<text x="5000" text="graph.values.x_k" text:value="5"/>
				<text x="10000" text="graph.values.x_k" text:value="10"/>
				<text x="20000" text="graph.values.x_k" text:value="20"/>
			</ui:with>

			<!-- Button quantize -->
			<embed oy="4" start.x="18000" start.y="20" end.x="18000" end.y="44" valign="1" halign="0" alpha="0">
				<button id="quant" font.name="lsp-icons" font.size="12" size="24" text="icons.other.quantize_note"/>
			</embed>

			<ui:with x="10" halign="1" pgroup="0" priority="10">
				<text y="0 db" text="0" valign="1" priority="0"/>
				<text y="1" ox="0" oy="2" text="graph.units.db" valign="-1" priority="0"/>

				<ui:for id="g" counter="i" list="+36;+24;+12;-12;-24;-36">
					<text y="${g} db" text="${g}" valign="-1"/>
				</ui:for>
			</ui:with>

		</graph>
	</grid>
</plugin>
