<plugin resizable="true">
	<grid rows="3" cols="2" spacing="4">
		<group ipadding="0" expand="true" fill="true" text="labels.graphs.frequency">
			<graph ui:id="profile_graph" width.min="640" height.min="380" expand="true">
				<origin hpos="-1" vpos="-1" visible="false"/>
	
				<!-- Gray grid -->
				<ui:for id="g" first="-36" last="36" step="24">
					<marker v="${g} db" ox="1" oy="0" color="graph_alt_1"/>
				</ui:for>
				<ui:with ox="0" oy="1">
					<ui:for id="f" first="20" last="90" step="10">
						<marker v="${f}" color="graph_alt_1"/>
					</ui:for>
					<ui:for id="f" first="200" last="900" step="100">
						<marker v="${f}" color="graph_alt_1"/>
					</ui:for>
					<ui:for id="f" first="2000" last="9000" step="1000">
						<marker v="${f}" color="graph_alt_1"/>
					</ui:for>
					<marker value="20000" color="graph_alt_1"/>
				</ui:with>
	
				<!-- Yellow grid -->
				<ui:with ox="0" oy="1" color="graph_sec">
					<marker v="100"/>
					<marker v="1000"/>
					<marker v="10000"/>
				</ui:with>
				<ui:with ox="1" oy="0" color="graph_sec">
					<marker v="+24 db"/>
					<marker v="0 db"/>
					<marker v="-24 db"/>
				</ui:with>
	
				<!-- Piano keys -->
				<embed oy="2" start.x="midi_freq_start(12, 127)" start.y="20" end.x="midi_freq_end(12, 127)" end.y="44" valign="1" alpha="0" visibility=":_ui_graph_piano_layout">
					<piano natural="false" note.min="12" note.max="127" height="24" editable="false" selectable="false" border="0"/>
				</embed>
	
				<!-- Octave text -->
				<ui:with ox="0" oy="2" y="44" halign="1" valign="1" pgroup="0" priority="10" visibility=":_ui_graph_piano_layout" pad.b="2">
					<ui:for id="octave" first="0" last="9">
						<text x="midi_freq(12 * ${:octave + 1})" text="lists.notes.fmt.c" text:octave="${octave}" valign="1" halign="0"/>
					</ui:for>
				</ui:with>
	
				<!-- Axis -->
				<axis ui:id="matcher_ox" min="10" max="24000" color="graph_prim" angle="0.0" log="true" visibility="false"/>
				<axis ui:id="matcher_oy" min="-48 db" max="48 db" color="graph_prim" angle="0.5" log="true" visibility="false"/>
				<axis min="0" max=":_a_scaled_height" visibility="false" angle="0.5"/>
				<axis min="0" max="1" visibility="false" angle="0.5"/>
				
				<ui:set id="hide_cond" value="(:showfil or :showenv or :showlim)" />
				<ui:set id="hide_cond_soft" value="(:showfil or :showenv)" />
				<!-- Meshes -->
				<ui:if test="!ex :out_r">
					<mesh id="fft" xi="0" yi="1" width="0" color="mono_in" color.a="0.8" fcolor.a="0.8" fill="true" fcolor="left_in" visibility=":showfft and :ife" />
					<mesh id="fft" xi="0" yi="2" width="2" color="mono_in" visibility=":showfft and :rfe"/>
					<mesh id="fft" xi="0" yi="3" width="2" color="mono_in" visibility=":showfft and :cfe"/>
					<mesh id="fft" xi="0" yi="4" width="2" color="mono" visibility=":showfft and :ofe"/>
					
					<!-- Dynamic input profile -->
					<mesh id="pmesh" xi="0" yi="2" width="2" color="mono" visibility="(:showpro and :pife) or (:track and (:in_src ieq 1) and not ${hide_cond})" />
					<!-- Reference profile -->
					<mesh id="pmesh" xi="0" yi="3" width="2" color="mono" visibility="(:showpro and :prfe) or (:track and (:ref_src ige 3) and not ${hide_cond})" />
					<!-- Static input profile -->
					<mesh id="pmesh" xi="0" yi="4" width="2" color="mono" visibility="(:showpro and :psfe) or ((:in_src ieq 0) and :profile and not ${hide_cond})" />
					<!-- Capture input profile -->
					<mesh id="pmesh" xi="0" yi="5" width="2" color="mono" visibility="(:showpro and :pcfe) or ((:ref_src ilt 3) and :capture and not ${hide_cond})" />
					<!-- File profile -->
					<mesh id="pmesh" xi="0" yi="6" width="2" color="mono" visibility="(:showpro and :pffe) or :showfil" />
					<!-- Envelope -->
					<mesh id="pmesh" xi="0" yi="7" width="2" color="mono" visibility="(:showpro and :pefe) or :showenv" />
					<!-- Envelope maximum bounds -->
					<mesh id="pmesh" xi="0" yi="8" width="2" color="threshold" visibility=":limit or :showlim" />
					<!-- Envelope minimum bounds -->
					<mesh id="pmesh" xi="0" yi="9" width="2" color="threshold" visibility=":limit or :showlim" />
					<!-- Match profile -->
					<mesh id="pmesh" xi="0" yi="1" width="2" color="mono" visibility=":pmfe and not ${hide_cond_soft}" />
				</ui:if>
				<ui:if test="ex :out_r">
					<!-- Input -->
					<mesh id="fft" xi="0" yi="1" width="0" color="left_in" color.a="0.8" fcolor.a="0.8" fill="true" fcolor="left_in" visibility=":showfft and :ife_l" />
					<mesh id="fft" xi="0" yi="5" width="0" color="right_in" color.a="0.8" fcolor.a="0.8" fill="true" fcolor="right_in" visibility=":showfft and :ife_r" />
					<!-- Capture -->
					<mesh id="fft" xi="0" yi="3" width="2" color="left_in" visibility=":showfft and :cfe_l"/>
					<mesh id="fft" xi="0" yi="7" width="2" color="right_in" visibility=":showfft and :cfe_r"/>
					<!-- Reference -->
					<mesh id="fft" xi="0" yi="4" width="2" color="left_in" visibility=":showfft and :rfe_l"/>
					<mesh id="fft" xi="0" yi="8" width="2" color="right_in" visibility=":showfft and :rfe_r"/>
					<!-- Output -->
					<mesh id="fft" xi="0" yi="2" width="2" color="left_in" visibility=":showfft and :ofe_l"/>
					<mesh id="fft" xi="0" yi="6" width="2" color="right_in" visibility=":showfft and :ofe_r"/>
					
					<!-- Dynamic input profile -->
					<mesh id="pmesh" xi="0" yi="2" width="2" color="left" visibility="(:showpro and :pife_l) or (:track and (:in_src ieq 1) and not ${hide_cond})" />
					<mesh id="pmesh" xi="0" yi="11" width="2" color="right" visibility="(:showpro and :pife_r) or (:track and (:in_src ieq 1) and not ${hide_cond})" />
					<!-- Reference profile -->
					<mesh id="pmesh" xi="0" yi="3" width="2" color="left" visibility="(:showpro and :prfe_l) or (:track and (:ref_src ige 3) and not ${hide_cond})" />
					<mesh id="pmesh" xi="0" yi="12" width="2" color="right" visibility="(:showpro and :prfe_r) or (:track and (:ref_src ige 3) and not ${hide_cond})" />
					<!-- Static input profile -->
					<mesh id="pmesh" xi="0" yi="4" width="2" color="left" visibility="(:showpro and :psfe_l) or ((:in_src ieq 0) and :profile and not ${hide_cond})" />
					<mesh id="pmesh" xi="0" yi="13" width="2" color="right" visibility="(:showpro and :psfe_r) or ((:in_src ieq 0) and :profile and not ${hide_cond})" />
					<!-- Capture input profile -->
					<mesh id="pmesh" xi="0" yi="5" width="2" color="left" visibility="(:showpro and :pcfe_l) or ((:ref_src ilt 3) and :capture and not ${hide_cond})" />
					<mesh id="pmesh" xi="0" yi="14" width="2" color="right" visibility="(:showpro and :pcfe_r) or ((:ref_src ilt 3) and :capture and not ${hide_cond})" />
					<!-- File profile -->
					<mesh id="pmesh" xi="0" yi="6" width="2" color="left" visibility="(:showpro and :pffe_l) or :showfil" />
					<mesh id="pmesh" xi="0" yi="15" width="2" color="right" visibility="(:showpro and :pffe_r) or :showfil" />
					<!-- Envelope -->
					<mesh id="pmesh" xi="0" yi="7" width="2" color="left" visibility="(:showpro and :pefe_l) or :showenv" />
					<mesh id="pmesh" xi="0" yi="16" width="2" color="right" visibility="(:showpro and :pefe_r) or :showenv" />
					<!-- Envelope maximum bounds -->
					<mesh id="pmesh" xi="0" yi="8" width="2" color="threshold" visibility=":limit or :showlim" />
					<mesh id="pmesh" xi="0" yi="17" width="2" color="threshold" visibility=":limit or :showlim" />
					<!-- Envelope minimum bounds -->
					<mesh id="pmesh" xi="0" yi="9" width="2" color="threshold" visibility=":limit or :showlim" />
					<mesh id="pmesh" xi="0" yi="18" width="2" color="threshold" visibility=":limit or :showlim" />
					<!-- Match profile -->
					<mesh id="pmesh" xi="0" yi="1" width="2" color="left" visibility=":pmfe_l and not ${hide_cond_soft}" />
					<mesh id="pmesh" xi="0" yi="10" width="2" color="right" visibility=":pmfe_r and not ${hide_cond_soft}" />
				</ui:if>
				
				<!-- Text -->
				<ui:with ox="0" oy="2" y="0" halign="1" valign="1" pgroup="0" priority="0">
					<text x="10" text="graph.units.hz"/>
					<text x="20" text="20"/>
					<text x="30" text="30"/>
					<text x="50" text="50"/>
					<text x="100" text="100"/>
					<text x="200" text="200"/>
					<text x="300" text="300"/>
					<text x="500" text="500"/>
					<text x="1000" text="graph.values.x_k" text:value="1"/>
					<text x="2000" text="graph.values.x_k" text:value="2"/>
					<text x="3000" text="graph.values.x_k" text:value="3"/>
					<text x="5000" text="graph.values.x_k" text:value="5"/>
					<text x="10000" text="graph.values.x_k" text:value="10"/>
					<text x="20000" text="graph.values.x_k" text:value="20"/>
				</ui:with>
	
				<ui:with x="10" halign="1" pgroup="0" priority="10">
					<text y="0 db" text="0" valign="1" priority="0"/>
					<text y="1" ox="0" oy="3" text="graph.units.db" valign="-1" priority="0"/>
	
					<ui:for id="g" counter="i" list="+36;+24;+12;-12;-24;-36">
						<text y="${g} db" text="${g}" valign="-1"/>
					</ui:for>
				</ui:with>
	
			</graph>
		</group>
		
		<cell rows="3">
			<vbox>
				<!-- Signal -->
				<group text="groups.signal">
					<vbox>
						<knob id="g_in" pad.r="4"/>
						<vbox vfill="false">
							<label text="labels.input" halign="0"/>
							<value id="g_in" sline="true" halign="0"/>
						</vbox>
		
						<knob id="g_out" pad.r="4"/>
						<vbox vfill="false">
							<label text="labels.output" expand="true" halign="0"/>
							<value id="g_out" width.min="50" sline="true" halign="0"/>
						</vbox>
					</vbox>
				</group>
				
				<!-- Analysis -->
				<group text="groups.analysis" expand="true" ipadding="0">
					<vbox>
						<button id="showfft" text="actions.show" height="19" width="30" ui:inject="Button_mono_8"/>
						<ui:if test="!ex :out_r">
							<button id="ife" text="labels.chan.input" height="19" width="30" ui:inject="Button_mono_8"/>
							<button id="ofe" text="labels.chan.output" height="19" width="30" ui:inject="Button_mono_8"/>
							<button id="rfe" text="labels.chan.reference" height="19" width="30" ui:inject="Button_mono_8"/>
							<button id="cfe" text="labels.chan.capture" height="19" width="30" ui:inject="Button_mono_8"/>
						</ui:if>
						<ui:if test="ex :out_r">
							<grid rows="4" cols="3">
								<label text="labels.chan.input" />
								<button id="ife_l" text="labels.chan.L_eft" size="19" ui:inject="Button_left_8" />
								<button id="ife_r" text="labels.chan.R_ight" size="19" ui:inject="Button_right_8" />
								
								<label text="labels.chan.output" />
								<button id="ofe_l" text="labels.chan.L_eft" size="19" ui:inject="Button_left_8" />
								<button id="ofe_r" text="labels.chan.R_ight" size="19" ui:inject="Button_right_8" />
								
								<label text="labels.capture" />
								<button id="cfe_l" text="labels.chan.L_eft" size="19" ui:inject="Button_left_8" />
								<button id="cfe_r" text="labels.chan.R_ight" size="19" ui:inject="Button_right_8" />
								
								<label text="labels.chan.reference" />
								<button id="rfe_l" text="labels.chan.L_eft" size="19" ui:inject="Button_left_8" />
								<button id="rfe_r" text="labels.chan.R_ight" size="19" ui:inject="Button_right_8" />
							</grid>
						</ui:if>
	
						<grid rows="2" cols="2" transpose="false" hspacing="4" pad.v="4">
							<knob id="react" size="20" pad.r="4" pad.l="6"/>
							<vbox vfill="false" pad.r="6">
								<label text="labels.metering.reactivity" halign="0"/>
								<value id="react" width.min="50" sline="true" halign="0"/>
							</vbox>
	
							<knob id="shift" size="20" pad.r="4" pad.l="6"/>
							<vbox vfill="false" pad.r="6">
								<label text="labels.metering.shift" halign="0"/>
								<value id="shift" width.min="50" sline="true" halign="0"/>
							</vbox>
						</grid>
					</vbox>
				</group>
				<group text="groups.profiles" expand="true" ipadding="0">
					<vbox>
						<button id="showpro" text="actions.show" height="19" width="30" ui:inject="Button_mono_8"/>
						<label text="labels.static_profiles" />
						<ui:if test="!ex :out_r">
							<button id="psfe" text="labels.chan.input" height="19" width="30" ui:inject="Button_mono_8"/>
							<button id="pcfe" text="labels.capture" height="19" width="30" ui:inject="Button_mono_8"/>
							<button id="pffe" text="labels.file" height="19" width="30" ui:inject="Button_mono_8"/>
							<button id="pefe" text="labels.signal.envelope" height="19" width="30" ui:inject="Button_mono_8"/>
						</ui:if>
						<ui:if test="ex :out_r">
							<grid rows="4" cols="3">
								<label text="labels.chan.input" />
								<button id="psfe_l" text="labels.chan.L_eft" size="19" ui:inject="Button_left_8" />
								<button id="psfe_r" text="labels.chan.R_ight" size="19" ui:inject="Button_right_8" />
								
								<label text="labels.capture" />
								<button id="pcfe_l" text="labels.chan.L_eft" size="19" ui:inject="Button_left_8" />
								<button id="pcfe_r" text="labels.chan.R_ight" size="19" ui:inject="Button_right_8" />
								
								<label text="labels.file" />
								<button id="pffe_l" text="labels.chan.L_eft" size="19" ui:inject="Button_left_8" />
								<button id="pffe_r" text="labels.chan.R_ight" size="19" ui:inject="Button_right_8" />
								
								<label text="labels.signal.envelope" />
								<button id="pefe_l" text="labels.chan.L_eft" size="19" ui:inject="Button_left_8" />
								<button id="pefe_r" text="labels.chan.R_ight" size="19" ui:inject="Button_right_8" />
							</grid>
						</ui:if>
						
						<label text="labels.dynamic_profiles" />
						<ui:if test="!ex :out_r">
							<button id="pife" text="labels.chan.input" height="19" width="30" ui:inject="Button_mono_8"/>
							<button id="prfe" text="labels.chan.reference" height="19" width="30" ui:inject="Button_mono_8"/>
						</ui:if>
						<ui:if test="ex :out_r">
							<grid rows="3" cols="3">
								<label text="labels.chan.input" />
								<button id="pife_l" text="labels.chan.L_eft" size="19" ui:inject="Button_left_8" />
								<button id="pife_r" text="labels.chan.R_ight" size="19" ui:inject="Button_right_8" />
								
								<label text="labels.chan.reference" />
								<button id="prfe_l" text="labels.chan.L_eft" size="19" ui:inject="Button_left_8" />
								<button id="prfe_r" text="labels.chan.R_ight" size="19" ui:inject="Button_right_8" />
							</grid>
						</ui:if>
						
						<label text="labels.result" />
						<ui:if test="!ex :out_r">
							<button id="prfe" text="labels.signal.match" height="19" width="30" ui:inject="Button_mono_8"/>
						</ui:if>
						<ui:if test="ex :out_r">
							<grid rows="1" cols="3">
								<label text="labels.signal.match" />
								<button id="pmfe_l" text="labels.chan.L_eft" size="19" ui:inject="Button_left_8" />
								<button id="pmfe_r" text="labels.chan.R_ight" size="19" ui:inject="Button_right_8" />
							</grid>
						</ui:if>
					</vbox>
				</group>
			</vbox>
		</cell>
		
		<hbox hfill="true" pad.h="6" pad.v="4" bg.color="bg_schema">
			<label text="labels.fft.frame" />
			<combo id="fft_sz" />
			<label text="labels.input" />
			<combo id="in_src" />
			<label text="labels.signal.reference" />
			<combo id="ref_src" />
			<button id="track" text="actions.tracking" />
			
			<vsep />
			
			<void hexpand="true" />
			
			<vsep />
			<label text="labels.blend" />
			<knob id="blend" />
			<value id="blend" />
			
			<ui:if test="ex :out_r">
				<label text="labels.stereo_link" />
				<knob id="slink" />
				<value id="slink" />
			</ui:if>
			
			<vsep />
			
			<shmlink id="link" pad.v="4" pad.l="2"/>
		</hbox>
		<hbox hfill="true" pad.h="6" pad.v="4" bg.color="bg_schema">
			<label text="labels.signal.input" />
			<knob id="rct_in" />
			<value id="rct_in" sline="true" />
			<button id="profile" text="actions.record" />
			
			<vsep />
			
			<label text="labels.capture" />
			<combo id="cap_src" />
			<button id="capture" text="actions.record" />
			
			<vsep />
			
			<label text="labels.signal.reference" />
			<knob id="rct_ref" />
			<value id="rct_ref" sline="true" />
			
			<vsep />
			
			<button ui:id="profile_file_trigger" id="showfil" text="labels.file" />
			
			<vsep />
			
			<button ui:id="profile_envelope_trigger" id="showenv" text="labels.signal.envelope" />
			
			<vsep />
			
			<button ui:id="profile_limit_trigger" id="showlim" text="actions.limits" />
			<button ui:id="profile_morphing_trigger" id="showmrp" text="actions.morphing" />
		</hbox>
	</grid>
	
	<!-- Profile envelope overlay -->
	<overlay id="showenv" trigger="profile_envelope_trigger" hpos="1" vpos="0" halign="-1" valign="-1" ipadding.b="4">
		<group text="groups.envelope">
			<grid rows="3" cols="10" heifht.min="96">
				<label text="25"/>
				<label text="50"/>
				<label text="107"/>
				<label text="227"/>
				<label text="484"/>
				<label text="labels.flt.x_k" text:value="1" />
				<label text="labels.flt.x_k" text:value="2.2" />
				<label text="labels.flt.x_k" text:value="4.7" />
				<label text="labels.flt.x_k" text:value="10" />
				<label text="labels.flt.x_k" text:value="16" />

				<ui:for id="i" first="1" count="10">
					<fader id="ref_${i}" angle="1" />
				</ui:for>
				<ui:for id="i" first="1" count="10">
					<value id="ref_${i}" />
				</ui:for>
			</grid>
		</group>
	</overlay>
	
	<!-- Profile limiting overlay -->
	<overlay id="showlim" trigger="profile_limit_trigger" hpos="1" vpos="0" halign="-1" valign="-1" ipadding.b="4">
		<group text="groups.profile_limits">
			<grid rows="5" cols="10" heifht.min="96">
				<cell cols="10">
					<hbox>
						<void hexpand="true" />
						<button id="limit" text="labels.enable" />
					</hbox>
				</cell>
				<label text="25"/>
				<label text="50"/>
				<label text="107"/>
				<label text="227"/>
				<label text="484"/>
				<label text="labels.flt.x_k" text:value="1" />
				<label text="labels.flt.x_k" text:value="2.2" />
				<label text="labels.flt.x_k" text:value="4.7" />
				<label text="labels.flt.x_k" text:value="10" />
				<label text="labels.flt.x_k" text:value="16" />

				<ui:for id="i" first="1" count="10">
					<range end.id="amp_${i}" start.id="red_${i}" min="-36" max="36" angle="1" />
				</ui:for>
				<ui:for id="i" first="1" count="10">
					<value id="red_${i}" detailed="false" />
				</ui:for>
				<ui:for id="i" first="1" count="10">
					<value id="amp_${i}" />
				</ui:for>
			</grid>
		</group>
	</overlay>
	
	<!-- Profile morphing -->
	<overlay id="showmrp" trigger="profile_morphing_trigger" hpos="1" vpos="0" halign="-1" valign="-1" ipadding.b="4">
		<group text="groups.profile_morphing">
			<grid rows="4" cols="10" heifht.min="96">
				<cell cols="10">
					<label text="labels.reactivity" />
				</cell>
				<label text="25"/>
				<label text="50"/>
				<label text="107"/>
				<label text="227"/>
				<label text="484"/>
				<label text="labels.flt.x_k" text:value="1" />
				<label text="labels.flt.x_k" text:value="2.2" />
				<label text="labels.flt.x_k" text:value="4.7" />
				<label text="labels.flt.x_k" text:value="10" />
				<label text="labels.flt.x_k" text:value="16" />

				<ui:for id="i" first="1" count="10">
					<knob id="spd_${i}" />
				</ui:for>
				<ui:for id="i" first="1" count="10">
					<value id="spd_${i}" />
				</ui:for>
			</grid>
		</group>
	</overlay>
	
	<!-- File loading -->
	<overlay id="showfil" trigger="profile_morphing_trigger" hpos="1" vpos="0" halign="-1" valign="-1" ipadding.b="4">
		<group text="groups.file" bg.color="bg" spacing="0" ipadding="0">
			<vbox>
				<hbox width.min="300" height.min="192" expand="true">
					<asample
						expand="true"
						id="file"
						mesh_id="fmesh"
						path.id="_ui_dlg_sample_path"
						ftype.id="_ui_dlg_sample_ftype"
						play.position=":fppos"
						hcut=":fhcut"
						tcut=":ftcut"
						length=":flength"
						status=":fstatus"
						load.preview="true"
						clipboard.head_cut="fhcut"
						clipboard.tail_cut="ftcut"
						format="audio_lspc,audio,all" />

					<void bg.color="bg_graph" pad.h="2" hreduce="true" visibility=":fstatus ine 1" />

					<vbox vexpand="true" visibility=":fstatus ine 1">
						<void bg.color="bg_graph" pad.v="2" vreduce="true"/>
						<afolder id="file" expand="true" width.min="199"/>
						<void bg.color="bg_graph" pad.v="2" vreduce="true"/>

						<ui:with fill="true">
							<hbox pad.h="6" pad.v="4" spacing="4" bg.color="bg_schema">
								<ui:with height="22">
									<anavigator id="file" text="icons.navigation_big.first_alt" action="first" />
									<anavigator id="file" text="icons.navigation_big.last_alt" action="last" />
									<void hexpand="true"/>
									<anavigator id="file" text="icons.navigation_big.previous" action="previous" />
									<anavigator id="file" text="icons.navigation_big.next" action="next" />
									<void hexpand="true"/>

									<anavigator id="file" text="icons.random.dice_fill" action="random" />
									<void hexpand="true"/>
									<anavigator id="file" text="icons.actions.cancel_alt" action="clear" />
								</ui:with>
							</hbox>
						</ui:with>
					</vbox>
				</hbox>
				
				<void bg.color="bg" pad.v="2" vreduce="true"/>

				<grid rows="4" cols="4" bg.color="bg_schema" >
					<ui:with pad.h="6" pad.v="4" vreduce="true">
						<label text="labels.sedit.pitch"/>
						<label text="labels.sedit.head_cut"/>
						<label text="labels.sedit.tail_cut"/>
						<label text="labels.listen"/>
					</ui:with>

					<cell cols="4"><hsep bg.color="bg" pad.v="2" vreduce="true"/></cell>

					<ui:with pad.h="6" pad.v="4">
						<knob id="fpitch" />
						<knob id="fhcut" />
						<knob id="ftcut" />
						<cell rows="2">
							<hbox fill="false">
								<ui:with font.name="lsp-icons" font.size="10" size="32" ui:inject="Button_cyan" toggle="false">
									<button id="fplay" text="icons.playback_big.play"/>
									<button id="fstop" text="icons.playback_big.stop"/>
								</ui:with>
							</hbox>
						</cell>
					</ui:with>

					<ui:with pad.h="6" pad.b="4" width.min="48" sline="true">
						<value id="fpitch"/>
						<value id="fhcut"/>
						<value id="ftcut"/>
					</ui:with>
					
				</grid>
			</vbox>
		</group>
	</overlay>
</plugin>
